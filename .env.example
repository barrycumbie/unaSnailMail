# Environment Variables for UNA Snail Mail System

# Server Configuration
NODE_ENV=development
PORT=8080

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/una-snail-mail

# JWT Configuration
JWT_SECRET=una-snail-mail-secret-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=una-snail-mail-refresh-secret
JWT_REFRESH_EXPIRE=30d

# Demo Mode
DEMO_MODE=false

# Logging
LOG_LEVEL=info

# External API Keys (for carrier integrations)
UPS_API_KEY=your-ups-api-key
UPS_API_SECRET=your-ups-api-secret
USPS_API_KEY=your-usps-api-key
FEDEX_API_KEY=your-fedex-api-key
AMAZON_API_KEY=your-amazon-api-key

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@una.edu
SMTP_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Subdomain Configuration
RECIPIENT_SUBDOMAIN=mail
ADMIN_SUBDOMAIN=admin
DEMO_SUBDOMAIN=demo